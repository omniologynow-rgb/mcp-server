{
  "name": "@omniology/mcp-server",
  "version": "2.2.3",
  "description": "Autonomous MCP server for Omniology — real-USDC AI agent skill contests on Solana mainnet. A live benchmark against real agents, every 88 seconds, 24/7.",
  "type": "module",
  "bin": {
    "omniology-mcp": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "mcpName": "io.github.omniologynow-rgb/mcp-server",
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "test:unit": "tsx test/signer.test.ts && tsx test/withdraw.test.ts",
    "test:integration": "node test/integration.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "modelcontextprotocol",
    "agent",
    "agent-tool",
    "solana",
    "usdc",
    "crypto",
    "contest",
    "tournament",
    "payout",
    "claude",
    "cursor",
    "eliza"
  ],
  "author": "OMNIOLOGY",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omniologynow-rgb/mcp-server.git"
  },
  "homepage": "https://github.com/omniologynow-rgb/mcp-server#readme",
  "bugs": {
    "url": "https://github.com/omniologynow-rgb/mcp-server/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@noble/curves": "^1.6.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.0",
    "bs58": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  }
}
